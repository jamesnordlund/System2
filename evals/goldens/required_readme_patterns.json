{
  "description": "Patterns that must appear in README.md and patterns that must NOT appear",
  "version": "0.3.0",
  "must_contain": [
    {
      "id": "readme-marketplace-add",
      "pattern": "plugin marketplace add jamesnordlund/System2",
      "description": "Plugin marketplace add command"
    },
    {
      "id": "readme-plugin-install",
      "pattern": "plugin install system2@jamesnordlund-system2",
      "description": "Plugin install command"
    },
    {
      "id": "readme-init-command",
      "pattern": "system2:init",
      "description": "Init slash command reference"
    },
    {
      "id": "readme-force-flag",
      "pattern": "--force",
      "description": "Force flag documentation"
    },
    {
      "id": "readme-migration",
      "pattern": "[Mm]igrat",
      "is_regex": true,
      "description": "Migration section present"
    }
  ],
  "must_not_contain": [
    {
      "id": "readme-no-curl",
      "pattern": "curl ",
      "description": "No curl commands in README"
    },
    {
      "id": "readme-no-update-system2",
      "pattern": "/update-system2",
      "description": "No /update-system2 command references"
    },
    {
      "id": "readme-no-old-hook-paths",
      "pattern": "CLAUDE_PROJECT_DIR.*\\.claude/hooks",
      "is_regex": true,
      "description": "No old-style hook path references"
    }
  ]
}
